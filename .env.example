# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings → API). The anon key is safe to expose client-side;
# Row Level Security is the actual data boundary.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (also add in Vercel): powers the AI "best time to visit" text.
# Get one at https://console.anthropic.com — without it, that one feature
# shows an error and everything else works.
ANTHROPIC_API_KEY=
